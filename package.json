{
"private": true,
"name": "solana-yield-adapter",
"version": "0.1.0",
"description": "Solana Yield Adapter Standard — dispatcher, registry, and five reference adapters",
"license": "MIT",
"workspaces": [
"sdk",
"tests"
],
"scripts": {
"build": "anchor build",
"test": "yarn ts-mocha -p ./tsconfig.json -t 1000000 'tests//*.test.ts'",
"test:unit": "yarn ts-mocha -p ./tsconfig.json -t 60000 'tests/unit//.test.ts'",
"test:integration": "yarn ts-mocha -p ./tsconfig.json -t 1000000 'tests/integration/**/.test.ts'",
"test:fork": "ANCHOR_PROVIDER_URL=https://api.mainnet-beta.solana.com yarn test:integration",
"lint": "eslint 'sdk/src//*.ts' 'tests//*.ts'",
"clean": "anchor clean && rm -rf node_modules sdk/node_modules",
"deploy:devnet": "anchor deploy --provider.cluster devnet",
"idl:generate": "anchor idl parse --file programs/yield-dispatcher/src/lib.rs -o sdk/src/idl/yield_dispatcher.json"
},
"devDependencies": {
"@types/bn.js": "^5.1.0",
"@types/chai": "^4.3.0",
"@types/mocha": "^9.1.0",
"@types/node": "^18.0.0",
"chai": "^4.3.6",
"mocha": "^9.2.0",
"ts-mocha": "^10.0.0",
"typescript": "^5.0.0",
"@typescript-eslint/eslint-plugin": "^6.0.0",
"@typescript-eslint/parser": "^6.0.0",
"eslint": "^8.0.0"
},
"dependencies": {
"@coral-xyz/anchor": "^0.31.1",
"@solana/spl-token": "^0.4.0",
"@solana/web3.js": "^1.91.0",
"bn.js": "^5.2.1"
}
}
