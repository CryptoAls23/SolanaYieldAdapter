{
"compilerOptions": {
"target": "ES2020",
"module": "commonjs",
"lib": ["ES2020"],
"declaration": true,
"declarationMap": true,
"sourceMap": true,
"outDir": "./dist",
"rootDir": ".",
"strict": true,
"esModuleInterop": true,
"resolveJsonModule": true,
"skipLibCheck": true,
"forceConsistentCasingInFileNames": true,
"moduleResolution": "node",
"allowSyntheticDefaultImports": true,
"experimentalDecorators": true,
"emitDecoratorMetadata": true,
"paths": {
"@yield-adapter/sdk": ["./sdk/src/index.ts"]
}
},
"include": [
"sdk/src//*.ts",
"tests//*.ts"
],
"exclude": [
"node_modules",
"dist",
"target"
]
}
